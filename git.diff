+                    level: 'warn',
+                    msg: `Unknown message type: ${(msg as { type: string }).type}`,
+                });
+        }
+    } catch (e) {
+        const err = e as Error;
+        send({
+            type: 'log',
+            level: 'error',
+            msg: `Error handling message ${msg.type}: ${err?.stack || err?.message || String(err)}`,
+        });
+    }
+});
